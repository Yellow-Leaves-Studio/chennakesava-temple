---
import Ornaments from '../components/Ornaments.astro';
import timings from '../data/timings.json';
import { PAGES as nav } from '../lib/pages.js';

const { title, description, showStatus = true } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (p) => `${base}${p}`;
const here = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'PlaceOfWorship',
  name: 'Sri Lakshmi Chennakesava Swami Devastanam',
  alternateName: 'శ్రీ లక్ష్మీ చెన్నకేశవ స్వామి దేవస్థానం',
  url: canonical,
  description:
    'A Vijayanagara-period temple to Vishnu as Chennakesava Swamy, on the Gundlakamma at Markapuram, Prakasam District, Andhra Pradesh.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Markapuram',
    addressRegion: 'Andhra Pradesh',
    postalCode: '523316',
    addressCountry: 'IN',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 15.7349, longitude: 79.2691 },
  openingHours: ['Su-Fr 06:00-20:30', 'Sa 06:00-12:00', 'Sa 17:00-20:30'],
  isAccessibleForFree: true,
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <!-- Must run before first paint, or a visitor who chose light gets a dark flash on
       every page load. Inline and blocking on purpose. Do not move or defer this. -->
  <script is:inline>
    try {
      var t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
    } catch (e) {}
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Sri Lakshmi Chennakesava Swami Devastanam" />
  <meta property="og:locale" content="en_IN" />
  <meta name="twitter:card" content="summary" />
  <!-- No og:image: no photograph of this temple is legally usable yet, and SVG is not
       accepted as one. Add the gopuram in Phase 2. See §10a. -->
  <link rel="icon" href={url('/favicon.svg')} type="image/svg+xml" />
  <link rel="apple-touch-icon" href={url('/favicon.svg')} />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</head>
<body>
  <Ornaments />

  <a class="skip" href="#main">Skip to content</a>

  <header class="band masthead">
    <svg class="masthead-chakra" viewBox="0 0 200 200" aria-hidden="true"><use href="#chakra" /></svg>
    <a class="crest band-inner" href={url('/')}>
      <svg class="namam" viewBox="0 -3 24 39" aria-hidden="true"><use href="#namam" /></svg>
      <span class="crest-te">శ్రీ లక్ష్మీ చెన్నకేశవ స్వామి దేవస్థానం</span>
      <span class="crest-en">Sri Lakshmi Chennakesava Swami Devastanam</span>
      <span class="crest-place">Markapur, Prakasam District &middot; <span class="te">మార్కాపురం</span></span>
    </a>
  </header>

  <!-- The band is full-bleed, its contents are not: hence the inner wrapper, which the
       other sections do not need. -->
  <nav class="band nav" aria-label="Main">
    <div class="band-inner nav-inner">
      {nav.map((n) => (
        <a href={url(n.href === '/' ? '/' : n.href)} aria-current={here === n.href ? 'page' : undefined}>{n.label}</a>
      ))}
      <!-- Both options shown rather than one toggle: standing in the sun outside the
           temple is not the moment to work out what a half-moon icon means. -->
      <span class="theme" role="group" aria-label="Page brightness">
        <button type="button" data-set-theme="light" aria-pressed="false">Light</button>
        <button type="button" data-set-theme="dark" aria-pressed="false">Dark</button>
      </span>
    </div>
  </nav>

  <!-- Below the nav, not above it: the menu then sits in the same place on every page,
       whether or not the badge is showing. -->
  {showStatus && (
    <div class="band status is-unknown" role="status" data-status-box>
      <span class="band-inner status-line">
        <span class="status-dot"></span>
        <span class="status-txt">
          <strong data-status-primary>Checking temple hours…</strong><span data-status-detail></span>
        </span>
      </span>
    </div>
  )}

  <main id="main">
    <slot />
  </main>

  <footer class="band band-top foot">
    <div class="band-inner foot-inner">
    <svg class="foot-lotus" viewBox="10 0 48 33" aria-hidden="true"><use href="#lotus" /></svg>
    <p class="disclaimer">
      An unofficial site maintained by devotees, not by the temple or the Endowments
      Department. Timings and festival dates are compiled from public sources and are
      <strong>not confirmed by the temple</strong>. Where sources disagree, the earliest
      closing time is published, so the temple may well be open later than stated, never
      earlier. Hours change on festival days.
    </p>
    <p class="disclaimer">
      No public telephone number is listed for this temple. Enquiries in person at the
      temple office.
    </p>
    </div>
  </footer>

  <script is:inline type="application/json" id="timings-data" set:html={JSON.stringify(timings)} />

  <script>
    import { status, display } from '../lib/status.js';

    // --- brightness ---------------------------------------------------------
    const root = document.documentElement;
    const themeButtons = document.querySelectorAll('[data-set-theme]');
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)');
    const activeTheme = () => root.dataset.theme || (systemDark.matches ? 'dark' : 'light');
    const syncTheme = () =>
      themeButtons.forEach((b) =>
        b.setAttribute('aria-pressed', String(b.dataset.setTheme === activeTheme())),
      );

    themeButtons.forEach((b) =>
      b.addEventListener('click', () => {
        root.dataset.theme = b.dataset.setTheme;
        try { localStorage.setItem('theme', b.dataset.setTheme); } catch (e) {}
        syncTheme();
      }),
    );
    syncTheme();
    // keep the control honest if the device flips to night mode while the page is open
    systemDark.addEventListener('change', syncTheme);

    // --- open or shut -------------------------------------------------------
    // One code path, however many presentations. The compact strip and the home hero are
    // both just markup carrying data-status-* ; adding a third means adding markup only.
    const boxes = document.querySelectorAll('[data-status-box]');
    if (boxes.length) {
      const timings = JSON.parse(document.getElementById('timings-data').textContent);
      const paint = () => {
        const s = status(timings);
        const state = s.open ? (s.note ? 'is-special' : 'is-open') : 'is-shut';
        const primary = s.open ? 'Open now' : 'Closed';
        const detail = s.open
          ? `${s.note ? s.note + ' · ' : ''}closes ${display(s.until)}`
          : s.until
            ? `opens ${display(s.until)}${s.nextDay ? ' tomorrow' : ''}`
            : '';

        boxes.forEach((box) => {
          box.classList.remove('is-unknown', 'is-open', 'is-shut', 'is-special');
          box.classList.add(state);
          const p = box.querySelector('[data-status-primary]');
          const d = box.querySelector('[data-status-detail]');
          if (p) p.textContent = primary;
          if (d) d.textContent = detail;
        });
      };
      paint();
      setInterval(paint, 60000);
    }
  </script>

  <style is:global>
    /* Light is the default. Dark applies when the device asks for it AND the visitor
       hasn't overridden to light. The :not() is what lets the toggle win in both
       directions without restating the light palette a second time. */
    :root {
      color-scheme: light;
      --ground: #EEF0EE; --surface: #F8F9F7; --line: #D3D8D4;
      --ink: #232A27; --ink-soft: #5D6A63;
      --kumkum: #96222A; --kumkum-soft: #F2E0DF;
      --gold: #A8781A; --gold-line: rgba(168,120,26,.68); --gold-glow: rgba(168,120,26,.13);
      /* watermark alpha is baked into the token, so it can differ per theme */
      --gold-veil: rgba(168,120,26,.24);
      --ink-place: #4C574F;
      --serif: "Iowan Old Style","Palatino Linotype",Palatino,"Book Antiqua",Georgia,serif;
      --sans: system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
      --mono: ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
      /* layout width, and the separate cap on running text. See §8: letting prose fill
         the wider container takes it from 84 to 95 characters a line. */
      --wrap: 52rem;
      --measure: 43rem;
    }
    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        color-scheme: dark;
        --ground: #171B1A; --surface: #1F2523; --line: #343C39;
        --ink: #E7EBE8; --ink-soft: #95A099;
        --kumkum: #DE8087; --kumkum-soft: #2E1D1C;
        --gold: #D6A63F; --gold-line: rgba(214,166,63,.40); --gold-glow: rgba(214,166,63,.10);
        --gold-veil: rgba(214,166,63,.20);
        --ink-place: #A6B0A9;
      }
    }
    :root[data-theme="dark"] {
      color-scheme: dark;
      --ground: #171B1A; --surface: #1F2523; --line: #343C39;
      --ink: #E7EBE8; --ink-soft: #95A099;
      --kumkum: #DE8087; --kumkum-soft: #2E1D1C;
      --gold: #D6A63F; --gold-line: rgba(214,166,63,.40); --gold-glow: rgba(214,166,63,.10);
      --gold-veil: rgba(214,166,63,.20);
      --ink-place: #A6B0A9;
    }

    *, *::before, *::after { box-sizing: border-box; }
    /* The page is --surface (paper). --ground is the recessed tone, for chrome and
       cards only. In the mockup --ground was the backdrop the phone frames sat on,
       never the site itself. Porting it onto body made the page read two-tone. */
    body {
      margin: 0; background: var(--surface); color: var(--ink);
      font-family: var(--sans); font-size: 18px; line-height: 1.62;
      -webkit-text-size-adjust: 100%;
    }
    img, svg { max-width: 100%; }

    .skip {
      position: absolute; left: -9999px; background: var(--kumkum); color: #fff;
      padding: 10px 16px; z-index: 10;
    }
    .skip:focus { left: 8px; top: 8px; }
    a:focus-visible { outline: 2px solid var(--kumkum); outline-offset: 3px; }

    /* ---- masthead ---- */
    /* Every band runs the full viewport; .band-inner holds its contents to the column.
       The rule is a gradient rather than a border so it can fade out instead of stopping
       dead. The fade sits entirely in the margin either side of the column, so the line
       is solid for the whole width of the text above it. Below 52rem that margin is
       zero, the gradient goes solid edge to edge, and nothing looks half-drawn. */
    .band { position: relative; }
    .band-inner { max-width: var(--wrap); margin-left: auto; margin-right: auto; width: 100%; }
    .band::after, .band-top::before {
      content: ""; position: absolute; left: 0; right: 0; height: 1px; pointer-events: none;
      background: linear-gradient(to right,
        transparent 0,
        var(--line) max(0px, calc((100% - var(--wrap)) / 2)),
        var(--line) calc(100% - max(0px, calc((100% - var(--wrap)) / 2))),
        transparent 100%);
    }
    .band::after { bottom: 0; }
    .band-top::before { top: 0; }

    .masthead {
      overflow: hidden; text-align: center;
      padding: 22px 20px 18px; background: var(--surface);
    }
    .masthead-chakra {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      width: 260px; height: 260px; color: var(--gold-veil); pointer-events: none;
    }
    .crest {
      position: relative; display: flex; flex-direction: column; align-items: center;
      gap: 3px; text-decoration: none; color: inherit;
    }
    .namam { width: 18px; color: var(--gold); margin-bottom: 5px; }
    .crest-te { font-size: 16px; line-height: 1.5; }
    .crest-en { font-family: var(--serif); font-size: 19px; line-height: 1.24; }
    .crest-place {
      font-family: var(--mono); font-size: 10px; letter-spacing: .14em;
      text-transform: uppercase; color: var(--ink-place); margin-top: 5px; font-size: 10.5px;
    }
    @media (min-width: 40rem) {
      .masthead { padding: 34px 20px 26px; }
      .crest-te { font-size: 20px; }
      .crest-en { font-size: 30px; }
    }

    /* ---- status badge ---- */
    .status { padding: 13px 20px; text-align: center; }
    .status-line { display: flex; align-items: center; justify-content: center; gap: 10px; }
    .status-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--ink-soft); flex: 0 0 auto; }
    .status-txt { font-size: 15.5px; }
    .status-txt [data-status-detail] { color: var(--ink-soft); }
    /* separator belongs to the strip only; the hero stacks its two lines instead */
    .status-txt [data-status-detail]:not(:empty)::before { content: " · "; }
    .is-open { background: var(--kumkum-soft); }
    .is-open .status-dot { background: var(--kumkum); box-shadow: 0 0 0 3px var(--kumkum-soft); }
    .is-special { background: var(--gold-glow); }
    .is-special .status-dot { background: var(--gold); box-shadow: 0 0 0 3px var(--gold-glow); }
    .is-unknown .status-txt { color: var(--ink-soft); }

    /* ---- nav ---- */
    /* Band tint fades in the margins too, on the same geometry as the rules. */
    .nav {
      background: linear-gradient(to right,
        transparent 0,
        var(--ground) max(0px, calc((100% - var(--wrap)) / 2)),
        var(--ground) calc(100% - max(0px, calc((100% - var(--wrap)) / 2))),
        transparent 100%);
    }
    /* Contents held to the column. Items cluster left and the control is pushed right by
       an auto margin, rather than space-between, which spread the six links apart and
       left gaps between them. On a phone the item padding comes down instead of the
       gutter: matching the gutter without that took the menu from two rows to three. */
    .nav-inner {
      padding: 10px 20px;
      display: flex; flex-wrap: wrap; align-items: center; gap: 2px 4px;
    }
    .nav .theme { margin-left: auto; }
    .nav a {
      padding: 7px 8px; font-size: 14.5px; color: var(--ink-soft);
      text-decoration: none; border-radius: 2px;
    }
    .nav a:hover { color: var(--ink); }
    .nav a[aria-current="page"] { color: var(--kumkum); font-weight: 600; }
    /* Pull the first item back by its own padding so its TEXT lands on the column edge,
       not its tap target. The brightness control is a bordered box, so its border is
       what should meet the right edge, and it needs no offset. */
    .nav a:first-child { margin-left: -8px; }
    @media (min-width: 40rem) {
      .nav a { padding: 7px 12px; }
      .nav a:first-child { margin-left: -12px; }
    }

    /* brightness control */
    .theme { display: inline-flex; border: 1px solid var(--line); border-radius: 2px; overflow: hidden; }
    .theme button {
      appearance: none; border: 0; background: transparent; cursor: pointer;
      font: inherit; font-size: 13px; padding: 6px 11px; color: var(--ink-soft);
      min-height: 34px; /* thumb target */
    }
    .theme button + button { border-left: 1px solid var(--line); }
    .theme button:hover { color: var(--ink); }
    .theme button[aria-pressed="true"] {
      background: var(--surface); color: var(--kumkum); font-weight: 600;
    }
    .theme button:focus-visible { outline: 2px solid var(--kumkum); outline-offset: -2px; }

    /* ---- main ---- */
    main { max-width: var(--wrap); margin: 0 auto; padding: 34px 20px 12px; }
    h1 {
      font-family: var(--serif); font-weight: 400; font-size: 22px; line-height: 1.22;
      margin: 0 0 6px; text-wrap: balance;
    }
    .page-te { color: var(--ink-soft); font-size: 17px; margin: 0 0 22px; }
    h2 {
      font-family: var(--serif); font-weight: 400; font-size: 23px; line-height: 1.24;
      margin: 30px 0 10px; text-wrap: balance;
    }
    h3 {
      display: flex; align-items: center; gap: 10px; margin: 30px 0 12px;
      font-family: var(--mono); font-size: 10.5px; letter-spacing: .15em;
      text-transform: uppercase; color: var(--ink-soft); font-weight: 500;
    }
    h3::after { content: ""; flex: 1; height: 1px; background: var(--line); }
    p { margin: 0 0 14px; }
    /* Running text stops at the measure; tables, charts and cards span the container. */
    main p, main > ul li, .lead, .sub { max-width: var(--measure); }
    main a { color: var(--kumkum); text-underline-offset: 2px; }
    /* A link that is a paragraph to itself is a control, not prose. Left inline it was an
       18px tap target; WCAG 2.2 asks for 24. Links inside a sentence are exempt and stay
       as they are. */
    main p > a:only-child { display: inline-block; padding: 7px 0; }
    strong { font-weight: 600; }
    @media (min-width: 40rem) { h1 { font-size: 25px; } h2 { font-size: 22px; } }

    /* ---- shared blocks ---- */
    /* Telugu carries vowel signs above and below the baseline, so at the same nominal
       size it reads larger and heavier than the Latin beside it. Optical correction,
       not hierarchy: em so it scales with whatever context it lands in. */
    .te { font-size: .9em; }
    /* Optical correction, not shrinking. Where the surrounding text is already at the
       smallest size on the page, 0.9em put Telugu at 9px, which is not readable at arm's
       length in sunlight. Those contexts opt out. */
    .crest-place .te, .site-place .te { font-size: 1em; }
    /* Out of sight, still read aloud. Used where a diagram carries the information
       visually but the same facts must reach a screen reader as real text. */
    .sr-only {
      position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0;
      overflow: hidden; clip: rect(0 0 0 0); clip-path: inset(50%); white-space: nowrap;
    }

    .lead { font-size: 19px; }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 16px; }
    th { text-align: left; font-weight: 600; font-size: 14px; color: var(--ink-soft); }
    td, th { padding: 9px 0; border-bottom: 1px solid var(--line); vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    td.num, th.num {
      text-align: right; font-family: var(--mono); font-size: 14px;
      font-variant-numeric: tabular-nums; white-space: nowrap;
    }
    /* Height matches the pattern tile exactly (60x24 and 24x20 user units, 1 unit = 1px
       with no viewBox), so the motif is never clipped and never squashed. */
    .kolam-rule, .petal-rule {
      display: block; width: 100%; color: var(--gold-line); margin: 30px 0;
    }
    .kolam-rule { height: 24px; }
    .petal-rule { height: 20px; }
    /* The rule does the separating. Without this the heading's own top margin collapses
       in on top of it, giving 30px after a kolam rule and 38px after a petal one. */
    .kolam-rule + *, .petal-rule + * { margin-top: 0; }

    .note {
      border-left: 2px solid var(--gold); background: var(--gold-glow);
      padding: 14px 16px; font-size: 15.5px; margin: 22px 0;
    }
    .note p:last-child { margin-bottom: 0; }

    .bud-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
    .bud-list li { display: flex; align-items: baseline; gap: 11px; }
    .bud-list svg { width: 10px; flex: 0 0 auto; color: var(--gold); align-self: center; }

    /* .card itself lives in components/Card.astro, alongside its muggu corners */
    .cards { display: grid; gap: 12px; margin-top: 8px; }
    @media (min-width: 34rem) { .cards { grid-template-columns: 1fr 1fr; } }

    /* ---- footer ---- */
    /* stretch, not centre: the disclaimers reach the column's edges like everything
       above them, instead of floating in a narrower block of their own */
    .foot { margin-top: 30px; }
    .foot-inner {
      padding: 26px 20px 44px;
      display: flex; flex-direction: column; align-items: stretch; text-align: center; gap: 12px;
    }
    /* --gold-line, not --gold with an opacity: layering an element opacity on top of an
       alpha token gave the lotus a different gold from the rules beside it. */
    .foot-lotus { width: 40px; color: var(--gold-line); align-self: center; }
    .disclaimer { font-size: 12.5px; line-height: 1.55; color: var(--ink-soft); margin: 0; }

    @media (prefers-reduced-motion: reduce) { *, *::before, *::after { transition: none !important; animation: none !important; } }
  </style>
</body>
</html>
