---
import Base from '../layouts/Base.astro';
import festivals from '../data/festivals.json';
import { groupDays, groupDate, groupLabel, groupNote } from '../lib/festivals.js';

const bram = festivals.brahmotsavam;
const groups = groupDays(bram.days);
---
<Base
  title="Festival calendar and Brahmotsavam | Chennakesava Swamy Temple, Markapur"
  description="The nineteen days of Brahmotsavam at Markapur: vahana sevas, Kalyanotsavam and Rathotsavam, with the temple's other annual observances."
>
  <h1>Festivals</h1>
  <p class="page-te">బ్రహ్మోత్సవాలు</p>

  <p class="lead">
    Brahmotsavam runs nineteen days and was begun in the time of the Vijayanagara rulers.
    On each night the utsava murti is carried on a different vahana, building to Garuda
    and then to the chariot. Rathotsavam has drawn crowds reported at over a lakh.
  </p>

  <div class="note">
    <p>
      <strong>These dates shift every year.</strong> They follow the lunar calendar, so the
      sequence below is for <strong>{bram.year}</strong> and will not hold for another
      year. It is entered by hand, once a year, on purpose. Computing panchangam dates
      gets them wrong in ways nobody notices until the page is wrong. Confirm with the
      temple before travelling.
    </p>
  </div>

  <h3>Brahmotsavam {bram.year}</h3>

  <!-- A procession, not a list. Runs of minor nights fold into one node so the two that
       matter are not buried among the vahana sevas either side of them. -->
  <ol class="ribbon">
    {groups.map((g) => (
      <li class:list={['rib', g.highlight && 'key']}>
        <span class="rib-date">{groupDate(g)}</span>
        <span class="rib-rail"><span class="node"></span></span>
        <span class="rib-name">
          {groupLabel(g)}
          {g.days[0].telugu && <span class="te rib-te">{g.days[0].telugu}</span>}
          {g.highlight && g.days[0].name.startsWith('Garuda') && (
            <span class="rib-note">The vahana of Vishnu himself</span>
          )}
          {g.highlight && g.days[0].name.startsWith('Rathotsavam') && (
            <span class="rib-note">The chariot. Over a lakh of devotees</span>
          )}
          {groupNote(g) && <span class="rib-note">{groupNote(g)}</span>}
        </span>
      </li>
    ))}
  </ol>

  <svg class="petal-rule" aria-hidden="true"><rect width="100%" height="100%" fill="url(#petalband)" /></svg>

  <h3>Through the year</h3>
  <div class="table-wrap">
    <table>
      <tbody>
        {festivals.observances.map((o) => (
          <tr>
            <td>{o.name}{o.telugu && <span class="te" style="color:var(--ink-soft)"> · {o.telugu}</span>}</td>
            <td class="num">{o.when}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>If you are coming for Rathotsavam</h2>
  <p>
    It is the busiest day of the temple's year by a wide margin. Darshan hours extend well
    beyond the usual, the town fills, and the walk from the bus stand takes considerably
    longer than it does on an ordinary morning.
  </p>
</Base>

<style>
  .ribbon { list-style: none; padding: 0; margin: 0; }
  .rib {
    display: grid; grid-template-columns: 4.6rem 22px 1fr; gap: 0 12px;
    align-items: start;
  }
  .rib-date {
    font-family: var(--mono); font-size: 11.5px; color: var(--ink-soft);
    text-align: right; padding-top: 10px; font-variant-numeric: tabular-nums;
  }
  .rib-rail { position: relative; align-self: stretch; }
  .rib-rail::before {
    content: ""; position: absolute; left: 10px; top: 0; bottom: 0;
    width: 1px; background: var(--line);
  }
  /* the rail starts and stops at the first and last node, not at the list edges */
  .rib:first-child .rib-rail::before { top: 15px; }
  .rib:last-child .rib-rail::before { bottom: calc(100% - 15px); }
  .node {
    position: absolute; left: 6px; top: 11px; width: 9px; height: 9px;
    border-radius: 50%; background: var(--surface);
    border: 1.5px solid var(--gold-line);
  }
  .rib.key .node {
    background: var(--kumkum); border-color: var(--kumkum);
    width: 11px; height: 11px; left: 5px; top: 10px;
  }
  .rib-name { padding: 5px 0 12px; font-size: 15.5px; }
  .rib.key .rib-name { font-family: var(--serif); font-size: 20px; line-height: 1.25; }
  .rib-te { color: var(--ink-soft); margin-left: 4px; }
  .rib-note {
    display: block; font-size: 13.5px; color: var(--ink-soft);
    font-family: var(--sans); margin-top: 1px;
  }
</style>
